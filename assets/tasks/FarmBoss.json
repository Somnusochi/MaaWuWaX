{
    "task": [
        {
            "name": "FarmBoss",
            "label": "$task.FarmBoss.label",
            "entry": "EchoFarm_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "farm"
            ],
            "option": [
                "BossType",
                "BossName",
                "BossProfile",
                "BossIndex",
                "BossLevel",
                "BossRepeatFarmCount",
                "BossCombatWaitTime",
                "BossEchoPickupMethod",
                "BossEchoUseLiberation",
                "BossEchoSwitchHealer"
            ]
        }
    ],
    "option": {
        "BossType": {
            "type": "select",
            "label": "$option.BossType.label",
            "default_case": "boss",
            "cases": [
                {
                    "name": "boss",
                    "label": "$option.BossType.cases.boss.label",
                    "pipeline_override": {
                        "EchoFarm_PostReviveProfile": {
                            "next": [
                                "EchoFarm_ReviveOpenMap"
                            ]
                        },
                        "EchoFarm_ReviveBackstep": {
                            "next": [
                                "EchoFarm_ReviveOpenBossBook"
                            ]
                        },
                        "EchoFarm_Main": {
                            "next": [
                                "EchoFarm_TeleportBoss"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_type": "boss",
                                "total_number": 20
                            }
                        },
                        "EchoFarm_BookOpen": {
                            "next": [
                                "EchoFarm_SelectBossTab"
                            ]
                        }
                    }
                },
                {
                    "name": "weekly",
                    "label": "$option.BossType.cases.weekly.label",
                    "pipeline_override": {
                        "EchoFarm_PostReviveProfile": {
                            "next": [
                                "EchoFarm_ReviveOpenMap"
                            ]
                        },
                        "EchoFarm_Main": {
                            "next": [
                                "EchoFarm_TeleportBoss"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_type": "weekly",
                                "total_number": 9
                            }
                        },
                        "EchoFarm_BookOpen": {
                            "next": [
                                "EchoFarm_SelectWeeklyTab"
                            ]
                        }
                    }
                }
            ]
        },
        "BossName": {
            "type": "input",
            "label": "$option.BossName.label",
            "inputs": [
                {
                    "name": "BossName",
                    "label": "OCR名称",
                    "description": "可选。填写后优先在索拉指南列表 OCR 查找 Boss 名称，找不到时回退到列表序号。",
                    "default": ""
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "boss_name": "{BossName}"
                    }
                }
            }
        },
        "BossProfile": {
            "type": "select",
            "label": "$option.BossProfile.label",
            "default_case": "Other",
            "cases": [
                {
                    "name": "Other",
                    "label": "$option.BossProfile.cases.Other.label"
                },
                {
                    "name": "Fallacy",
                    "label": "$option.BossProfile.cases.Fallacy.label",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterFallacyWalkRight"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatFallacyReset"
                            ]
                        },
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "fallacy"
                            }
                        }
                    }
                },
                {
                    "name": "Fenrico",
                    "label": "$option.BossProfile.cases.Fenrico.label",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterPromptRetryReset"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatFenricoReset"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "fenrico"
                            }
                        }
                    }
                },
                {
                    "name": "Lorelei",
                    "label": "$option.BossProfile.cases.lorelei.label",
                    "pipeline_override": {
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lorelei"
                            }
                        },
                        "EchoFarm_TeleportBoss": {
                            "next": [
                                "EchoFarm_LoreleiOpenMenu"
                            ]
                        }
                    }
                },
                {
                    "name": "LionessOfGlory",
                    "label": "$option.BossProfile.cases.lionessofglory.label",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lioness_of_glory"
                            }
                        }
                    }
                },
                {
                    "name": "NamelessExplorer",
                    "label": "$option.BossProfile.cases.NamelessExplorer.label",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterNamelessWalkForward"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatNamelessAdvance"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "nameless_explorer"
                            }
                        }
                    }
                },
                {
                    "name": "NightmareHecate",
                    "label": "$option.BossProfile.cases.nightmarehecate.label",
                    "pipeline_override": {
                        "EchoFarm_WaitRealmState": {
                            "next": [
                                "EchoFarm_Combat",
                                "EchoFarm_LocalStartNavigate"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "nightmare_hecate"
                            }
                        }
                    }
                },
                {
                    "name": "SentryConstruct",
                    "label": "$option.BossProfile.cases.SentryConstruct.label",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "sentry_construct"
                            }
                        }
                    }
                },
                {
                    "name": "Hyvatia",
                    "label": "$option.BossProfile.cases.Hyvatia.label",
                    "pipeline_override": {
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_HyvatiaResume"
                            ]
                        },
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 7
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "hyvatia"
                            }
                        }
                    }
                },
                {
                    "name": "LadyOfTheSea",
                    "label": "$option.BossProfile.cases.LadyOfTheSea.label",
                    "pipeline_override": {
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_HyvatiaResume"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lady_of_the_sea"
                            }
                        }
                    }
                }
            ]
        },
        "BossIndex": {
            "type": "input",
            "label": "$option.BossIndex.label",
            "inputs": [
                {
                    "name": "BossIndex",
                    "label": "列表序号",
                    "description": "F2索拉指南中从上到下的序号，强敌最多20，周本最多9。",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "default": "1"
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "serial_number": "{BossIndex}"
                    }
                }
            }
        },
        "BossLevel": {
            "type": "input",
            "label": "$option.BossLevel.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "80",
                    "pipeline_type": "string",
                    "verify": "^(50|60|70|80|90)$"
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "boss_level": "{value}"
                    }
                },
                "EchoFarm_SelectRealmLevel": {
                    "expected": "{value}"
                }
            }
        },
        "BossRepeatFarmCount": {
            "type": "input",
            "label": "刷多少次",
            "inputs": [
                {
                    "name": "value",
                    "default": "10000",
                    "pipeline_type": "int",
                    "verify": "[0-9]+"
                }
            ],
            "pipeline_override": {
                "EchoFarm_RoundGate": {
                    "custom_recognition_param": {
                        "counter_key": "echo_farm_round",
                        "max_count": "{value}"
                    }
                }
            }
        },
        "BossCombatWaitTime": {
            "type": "input",
            "label": "战斗开始前等待时间(秒)",
            "inputs": [
                {
                    "name": "value",
                    "default": "0",
                    "pipeline_type": "int",
                    "verify": "[0-9]+"
                }
            ],
            "pipeline_override": {
                "EchoFarm_AfterRealmEnterWaitCustom": {
                    "custom_action_param": {
                        "delay_seconds": "{value}"
                    }
                }
            }
        },
        "BossEchoPickupMethod": {
            "type": "select",
            "label": "搜索声骸方法",
            "default_case": "walk",
            "cases": [
                {
                    "name": "walk",
                    "label": "后退再前进",
                    "pipeline_override": {
                        "EchoFarm_CollectMove": {
                            "next": [
                                "EchoFarm_CollectMoveWalkBack"
                            ]
                        }
                    }
                },
                {
                    "name": "run_in_circle",
                    "label": "转圈奔跑",
                    "pipeline_override": {
                        "EchoFarm_CollectMove": {
                            "next": [
                                "EchoFarm_CollectMoveCircleForward"
                            ]
                        }
                    }
                }
            ]
        },
        "BossEchoUseLiberation": {
            "type": "switch",
            "label": "使用共鸣解放",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": false
                            }
                        }
                    }
                }
            ]
        },
        "BossEchoSwitchHealer": {
            "type": "switch",
            "label": "战斗结束后切换到治疗角色",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
