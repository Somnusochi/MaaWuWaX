{
    "task": [
        {
            "name": "AutoRogue",
            "label": "$task.AutoRogue.label",
            "entry": "Rogue_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "RogueStopOnTreasure",
                "RogueBuffFilter"
            ]
        }
    ],
    "option": {
        "RogueStopOnTreasure": {
            "type": "switch",
            "label": "$option.RogueStopOnTreasure.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Rogue_TreasureReward": {
                            "custom_action_param": {
                                "stop_on_treasure": true,
                                "max_claims": 2
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Rogue_TreasureReward": {
                            "custom_action_param": {
                                "stop_on_treasure": false,
                                "max_claims": 2
                            }
                        }
                    }
                }
            ]
        },
        "RogueBuffFilter": {
            "type": "input",
            "label": "$option.RogueBuffWhitelist.label",
            "inputs": [
                {
                    "name": "Whitelist",
                    "label": "$option.RogueBuffWhitelist.label",
                    "description": "逗号分隔，优先选择这些 Buff。",
                    "default": "心流,悲鸣纪,余音贝,齿轮之心,全知之眼,指南针,医疗箱,妄语的残谱,激越的残谱"
                },
                {
                    "name": "Blacklist",
                    "label": "$option.RogueBuffBlacklist.label",
                    "description": "逗号分隔，尽量避开这些 Buff。",
                    "default": "雷暴,旋风,矛盾晶体"
                }
            ],
            "pipeline_override": {
                "Rogue_BuffSelect": {
                    "custom_action_param": {
                        "whitelist": "{Whitelist}",
                        "blacklist": "{Blacklist}"
                    }
                }
            }
        }
    }
}
