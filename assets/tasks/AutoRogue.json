{
    "task": [
        {
            "name": "AutoRogue",
            "label": "$task.AutoRogue.label",
            "entry": "Rogue_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "RogueStopOnTreasure"
            ]
        }
    ],
    "option": {
        "RogueStopOnTreasure": {
            "type": "switch",
            "label": "$option.RogueStopOnTreasure.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Rogue_TreasureReward": {
                            "custom_action_param": {
                                "stop_on_treasure": true,
                                "max_claims": 2
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Rogue_TreasureReward": {
                            "custom_action_param": {
                                "stop_on_treasure": false,
                                "max_claims": 2
                            }
                        }
                    }
                }
            ]
        }
    }
}