{
    "task": [
        {
            "name": "AutoCombat",
            "label": "$task.AutoCombat.label",
            "entry": "Combat_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "combat"
            ],
            "option": [
                "CombatAutoTarget",
                "CombatUseLiberation",
                "CombatSwitchHealer"
            ]
        }
    ],
    "option": {
        "CombatAutoTarget": {
            "type": "switch",
            "label": "$option.CombatAutoTarget.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "auto_target": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "auto_target": false
                            }
                        }
                    }
                }
            ]
        },
        "CombatUseLiberation": {
            "type": "switch",
            "label": "$option.CombatUseLiberation.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "use_liberation": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "use_liberation": false
                            }
                        }
                    }
                }
            ]
        },
        "CombatSwitchHealer": {
            "type": "switch",
            "label": "战斗结束后切换治疗角色",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "switch_healer": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Combat_Engage": {
                            "custom_action_param": {
                                "switch_healer": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
