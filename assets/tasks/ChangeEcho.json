{
    "task": [
        {
            "name": "ChangeEcho",
            "label": "$task.ChangeEcho.label",
            "entry": "EchoChange_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "echo"
            ],
            "option": [
                "EchoTargetStat"
            ]
        }
    ],
    "option": {
        "EchoTargetStat": {
            "type": "select",
            "label": "$option.EchoTargetStat.label",
            "default_case": "attack",
            "cases": [
                {
                    "name": "attack",
                    "label": "$option.EchoTargetStat.cases.attack.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^(?:攻击|攻击力)$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^(?:攻击|攻击力)$"
                        }
                    }
                },
                {
                    "name": "crit_rate",
                    "label": "$option.EchoTargetStat.cases.crit_rate.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^(?:暴击|暴击率)$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^(?:暴击|暴击率)$"
                        }
                    }
                },
                {
                    "name": "crit_dmg",
                    "label": "$option.EchoTargetStat.cases.crit_dmg.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^暴击伤害$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^暴击伤害$"
                        }
                    }
                },
                {
                    "name": "hp",
                    "label": "$option.EchoTargetStat.cases.hp.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^(?:生命|生命值)$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^(?:生命|生命值)$"
                        }
                    }
                },
                {
                    "name": "def",
                    "label": "$option.EchoTargetStat.cases.def.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^(?:防御|防御力)$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^(?:防御|防御力)$"
                        }
                    }
                },
                {
                    "name": "con_eff",
                    "label": "$option.EchoTargetStat.cases.con_eff.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^共鸣效率$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^共鸣效率$"
                        }
                    }
                },
                {
                    "name": "glacio",
                    "label": "$option.EchoTargetStat.cases.glacio.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^冷凝伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^冷凝伤害加成$"
                        }
                    }
                },
                {
                    "name": "fusion",
                    "label": "$option.EchoTargetStat.cases.fusion.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^热熔伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^热熔伤害加成$"
                        }
                    }
                },
                {
                    "name": "electro",
                    "label": "$option.EchoTargetStat.cases.electro.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^导电伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^导电伤害加成$"
                        }
                    }
                },
                {
                    "name": "aero",
                    "label": "$option.EchoTargetStat.cases.aero.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^气动伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^气动伤害加成$"
                        }
                    }
                },
                {
                    "name": "spectro",
                    "label": "$option.EchoTargetStat.cases.spectro.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^衍射伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^衍射伤害加成$"
                        }
                    }
                },
                {
                    "name": "havoc",
                    "label": "$option.EchoTargetStat.cases.havoc.label",
                    "pipeline_override": {
                        "EchoChange_SelectTarget": {
                            "expected": "^湮灭伤害加成$"
                        },
                        "EchoChange_CheckCurrentStat": {
                            "expected": "^湮灭伤害加成$"
                        }
                    }
                }
            ]
        }
    }
}
