{
    "task": [
        {
            "name": "FarmMap",
            "label": "$task.FarmMap.label",
            "entry": "FarmMap_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "open_world"
            ],
            "option": [
                "FarmMapLocateBackend",
                {
                    "name": "FarmMapMaxStepDistance",
                    "label": "$option.FarmMapMaxStepDistance.label",
                    "type": "int",
                    "default": 144,
                    "pipeline_override": {
                        "FarmMap_LoadPath": {
                            "custom_action_param": {
                                "max_step_distance": 144,
                                "min_stars": 3
                            }
                        }
                    }
                },
                {
                    "name": "FarmMapReachDistance",
                    "label": "$option.FarmMapReachDistance.label",
                    "type": "int",
                    "default": 24,
                    "pipeline_override": {
                        "FarmMap_Walk": {
                            "custom_action_param": {
                                "reach_distance": 24,
                                "search_radius": 280,
                                "walk_ms": 850
                            }
                        }
                    }
                }
            ]
        }
    ],
    "option": {
        "FarmMapLocateBackend": {
            "type": "select",
            "label": "FarmMap 后端",
            "default_case": "cpp",
            "cases": [
                {
                    "name": "go",
                    "label": "Go Fallback",
                    "pipeline_override": {
                        "FarmMap_WaitWorld": {
                            "next": [
                                "FarmMap_Loop"
                            ]
                        },
                        "FarmMap_Locate": {
                            "custom_recognition": "FarmMapLocateRecognition",
                            "custom_recognition_param": {
                                "search_radius": 420
                            }
                        },
                        "FarmMap_Walk": {
                            "custom_action": "FarmMapWalkStep"
                        }
                    }
                },
                {
                    "name": "cpp",
                    "label": "cpp-algo Locate",
                    "pipeline_override": {
                        "FarmMap_WaitWorld": {
                            "next": [
                                "FarmMap_Locate"
                            ]
                        },
                        "FarmMap_Locate": {
                            "custom_recognition": "MapLocateRecognition",
                            "custom_recognition_param": {
                                "force_global_search": true
                            }
                        }
                    }
                }
            ]
        }
    }
}
