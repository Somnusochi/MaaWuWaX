{
    "task": [
        {
            "name": "FarmMap",
            "label": "$task.FarmMap.label",
            "entry": "FarmMap_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "open_world"
            ],
            "option": [
                "FarmMapLocateBackend",
                "FarmMapMaxStepDistance",
                "FarmMapReachDistance"
            ]
        }
    ],
    "option": {
        "FarmMapLocateBackend": {
            "type": "select",
            "label": "FarmMap 后端",
            "default_case": "cpp",
            "cases": [
                {
                    "name": "go",
                    "label": "Go Fallback",
                    "pipeline_override": {
                        "FarmMap_WaitWorld": {
                            "next": [
                                "FarmMap_Loop"
                            ]
                        },
                        "FarmMap_Locate": {
                            "custom_recognition": "FarmMapLocateRecognition",
                            "custom_recognition_param": {
                                "search_radius": 420
                            }
                        },
                        "FarmMap_Walk": {
                            "custom_action": "FarmMapWalkStep"
                        }
                    }
                },
                {
                    "name": "cpp",
                    "label": "cpp-algo Locate",
                    "pipeline_override": {
                        "FarmMap_WaitWorld": {
                            "next": [
                                "FarmMap_Locate"
                            ]
                        },
                        "FarmMap_Locate": {
                            "custom_recognition": "MapLocateRecognition",
                            "custom_recognition_param": {
                                "force_global_search": true
                            }
                        }
                    }
                }
            ]
        },
        "FarmMapMaxStepDistance": {
            "type": "input",
            "label": "$option.FarmMapMaxStepDistance.label",
            "inputs": [
                {
                    "name": "MaxStepDistance",
                    "default": "144",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FarmMap_LoadPath": {
                    "custom_action_param": {
                        "max_step_distance": "{MaxStepDistance}",
                        "min_stars": 3
                    }
                }
            }
        },
        "FarmMapReachDistance": {
            "type": "input",
            "label": "$option.FarmMapReachDistance.label",
            "inputs": [
                {
                    "name": "ReachDistance",
                    "default": "24",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FarmMap_Walk": {
                    "custom_action_param": {
                        "reach_distance": "{ReachDistance}",
                        "search_radius": 280,
                        "walk_ms": 850,
                        "stuck_steps": [
                            {
                                "key": "SPACE",
                                "step_ms": 80,
                                "delay_ms": 250
                            },
                            {
                                "key": "A",
                                "step_ms": 700,
                                "delay_ms": 250
                            },
                            {
                                "key": "D",
                                "step_ms": 700,
                                "delay_ms": 250
                            },
                            {
                                "key": "T",
                                "step_ms": 80,
                                "delay_ms": 250
                            }
                        ]
                    }
                }
            }
        }
    }
}
