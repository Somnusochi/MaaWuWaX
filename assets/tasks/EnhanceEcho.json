{
    "task": [
        {
            "name": "EnhanceEcho",
            "label": "$task.EnhanceEcho.label",
            "entry": "EchoEnhance_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "echo"
            ],
            "option": [
                "EchoNeedDoubleCrit",
                "EchoDoubleCritMin",
                "EchoFirstCritMin",
                "EchoValidStatsCount",
                "EchoFirstMustBeValid",
                "EchoAllValidBeforeCrit",
                "EchoValidStatsPreset",
                "EchoPauseOnSuccess"
            ]
        }
    ],
    "option": {
        "EchoNeedDoubleCrit": {
            "type": "switch",
            "label": "$option.EchoNeedDoubleCrit.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "need_double_crit": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "need_double_crit": false
                            }
                        }
                    }
                }
            ]
        },
        "EchoDoubleCritMin": {
            "type": "input",
            "label": "$option.EchoDoubleCritMin.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "13.8",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "EchoEnhance_Evaluate": {
                    "custom_action_param": {
                        "double_crit_min": "{value}"
                    }
                }
            }
        },
        "EchoValidStatsCount": {
            "type": "input",
            "label": "$option.EchoValidStatsCount.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "3",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "EchoEnhance_Evaluate": {
                    "custom_action_param": {
                        "valid_stats_min": "{value}"
                    }
                }
            }
        },
        "EchoFirstCritMin": {
            "type": "input",
            "label": "$option.EchoFirstCritMin.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "6.9",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "EchoEnhance_Evaluate": {
                    "custom_action_param": {
                        "first_crit_min": "{value}"
                    }
                }
            }
        },
        "EchoFirstMustBeValid": {
            "type": "switch",
            "label": "$option.EchoFirstMustBeValid.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "first_must_be_valid": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "first_must_be_valid": false
                            }
                        }
                    }
                }
            ]
        },
        "EchoAllValidBeforeCrit": {
            "type": "switch",
            "label": "$option.EchoAllValidBeforeCrit.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "all_valid_before_crit": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "all_valid_before_crit": false
                            }
                        }
                    }
                }
            ]
        },
        "EchoValidStatsPreset": {
            "type": "select",
            "label": "$option.EchoValidStatsPreset.label",
            "default_case": "crit_atk",
            "cases": [
                {
                    "name": "crit_atk",
                    "label": "$option.EchoValidStatsPreset.cases.crit_atk.label",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "valid_stats": [
                                    "暴击",
                                    "暴击伤害",
                                    "攻击百分比"
                                ]
                            }
                        }
                    }
                },
                {
                    "name": "crit_energy",
                    "label": "$option.EchoValidStatsPreset.cases.crit_energy.label",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "valid_stats": [
                                    "暴击",
                                    "暴击伤害",
                                    "攻击百分比",
                                    "共鸣效率"
                                ]
                            }
                        }
                    }
                },
                {
                    "name": "support",
                    "label": "$option.EchoValidStatsPreset.cases.support.label",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "valid_stats": [
                                    "暴击",
                                    "暴击伤害",
                                    "攻击百分比",
                                    "共鸣效率",
                                    "生命百分比",
                                    "防御百分比"
                                ]
                            }
                        }
                    }
                }
            ]
        },
        "EchoPauseOnSuccess": {
            "type": "switch",
            "label": "$option.EchoPauseOnSuccess.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "pause_on_success": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoEnhance_Evaluate": {
                            "custom_action_param": {
                                "pause_on_success": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
