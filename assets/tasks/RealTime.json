{
    "task": [
        {
            "name": "RealTime",
            "label": "$task.RealTime.label",
            "entry": "RealTime_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "realtime"
            ],
            "option": [
                "AutoCombat",
                "RealTimeCombatUseLiberation",
                "RealTimeCombatSwitchHealer",
                "RealTimeCombatChisaDPS",
                "RealTimeCombatIunoC6",
                "AutoPick",
                "RealTimeAutoPickFilter",
                "SkipDialog",
                "FastTravel",
                "AutoLogin",
                "MouseReset"
            ]
        }
    ],
    "option": {
        "AutoCombat": {
            "type": "switch",
            "label": "$option.AutoCombat.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoPick": {
            "type": "switch",
            "label": "$option.AutoPick.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Pick": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Pick": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "RealTimeAutoPickFilter": {
            "type": "input",
            "label": "实时拾取文本过滤",
            "inputs": [
                {
                    "name": "Whitelist",
                    "label": "白名单",
                    "description": "逗号分隔，匹配到这些文本时允许交互。",
                    "default": "吸收,Absorb"
                },
                {
                    "name": "Blacklist",
                    "label": "黑名单",
                    "description": "逗号分隔，匹配到这些文本时禁止交互。",
                    "default": "开始合成,领取奖励,Claim,合成台"
                }
            ],
            "pipeline_override": {
                "RealTime_Pick": {
                    "custom_recognition_param": {
                        "whitelist": "{Whitelist}",
                        "blacklist": "{Blacklist}"
                    }
                }
            }
        },
        "RealTimeCombatUseLiberation": {
            "type": "switch",
            "label": "$option.RealTimeCombatUseLiberation.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "use_liberation": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "use_liberation": false
                            }
                        }
                    }
                }
            ]
        },
        "RealTimeCombatSwitchHealer": {
            "type": "switch",
            "label": "战后切治疗",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "switch_healer": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "switch_healer": false
                            }
                        }
                    }
                }
            ]
        },
        "RealTimeCombatChisaDPS": {
            "type": "switch",
            "label": "Chisa 按主C站场",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "chisa_dps": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "chisa_dps": false
                            }
                        }
                    }
                }
            ]
        },
        "RealTimeCombatIunoC6": {
            "type": "switch",
            "label": "Iuno C6 按主C站场",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "iuno_c6": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Combat": {
                            "custom_action_param": {
                                "iuno_c6": false
                            }
                        }
                    }
                }
            ]
        },
        "SkipDialog": {
            "type": "switch",
            "label": "$option.SkipDialog.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Skip": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Skip": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FastTravel": {
            "type": "switch",
            "label": "$option.FastTravel.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Travel": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Travel": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "AutoLogin": {
            "type": "switch",
            "label": "$option.AutoLogin.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Login": {
                            "enabled": true
                        },
                        "Login_AfterAction": {
                            "next": ["RealTime_Main"]
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Login": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "MouseReset": {
            "type": "switch",
            "label": "$option.MouseReset.label",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "RealTime_Mouse": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "RealTime_Mouse": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
