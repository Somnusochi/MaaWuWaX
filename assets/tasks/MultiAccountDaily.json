{
    "task": [
        {
            "name": "MultiAccountDaily",
            "label": "$task.MultiAccountDaily.label",
            "entry": "MultiAccountDaily_Init",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "DailyNightmareMode",
                "StaminaType",
                "MultiAccountCount",
                "MultiAccountSelectionRetries"
            ],
            "pipeline_override": {
                "Daily_Done": {
                    "next": [
                        "MultiAccountDaily_SwitchGate"
                    ]
                },
                "Login_AfterAction": {
                    "next": [
                        "MultiAccountDaily_Login"
                    ]
                },
                "Daily_CheckNightmareExplicit": {
                    "enabled": false
                },
                "Daily_CheckNightmareCapture": {
                    "enabled": false
                },
                "Daily_SpendStamina": {
                    "enabled": true
                },
                "MultiAccountDaily_Switch": {
                    "custom_recognition_param": {
                        "max_accounts": 2
                    }
                }
            }
        }
    ],
    "option": {
        "MultiAccountCount": {
            "type": "select",
            "label": "$option.MultiAccountCount.label",
            "default_case": "all",
            "cases": [
                {
                    "name": "all",
                    "label": "全部账号",
                    "pipeline_override": {
                        "MultiAccountDaily_Switch": {
                            "custom_recognition_param": {
                                "max_accounts": 0
                            }
                        }
                    }
                },
                {
                    "name": "2",
                    "label": "2 个账号",
                    "pipeline_override": {
                        "MultiAccountDaily_Switch": {
                            "custom_recognition_param": {
                                "max_accounts": 2
                            }
                        }
                    }
                },
                {
                    "name": "3",
                    "label": "3 个账号",
                    "pipeline_override": {
                        "MultiAccountDaily_Switch": {
                            "custom_recognition_param": {
                                "max_accounts": 3
                            }
                        }
                    }
                },
                {
                    "name": "4",
                    "label": "4 个账号",
                    "pipeline_override": {
                        "MultiAccountDaily_Switch": {
                            "custom_recognition_param": {
                                "max_accounts": 4
                            }
                        }
                    }
                }
            ]
        },
        "MultiAccountSelectionRetries": {
            "type": "input",
            "label": "账号切换重试次数",
            "inputs": [
                {
                    "name": "SelectionRetryLimit",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d*$"
                }
            ],
            "pipeline_override": {
                "MultiAccountDaily_SelectionRetryGate": {
                    "custom_recognition_param": {
                        "counter_key": "multi_account_select_retry",
                        "max_count": "{SelectionRetryLimit}"
                    }
                }
            }
        }
    }
}
