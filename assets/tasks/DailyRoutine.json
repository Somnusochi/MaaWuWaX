{
    "task": [
        {
            "name": "DailyRoutine",
            "label": "$task.DailyRoutine.label",
            "entry": "Daily_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "daily"
            ],
            "pipeline_override": {
                "Daily_CheckNightmareExplicit": {
                    "enabled": false
                },
                "Daily_CheckNightmareCapture": {
                    "enabled": false
                },
                "Daily_SpendStamina": {
                    "enabled": true
                }
            },
            "option": [
                "ClaimMail",
                "ClaimBattlePass",
                "DailyNightmareMode",
                "StaminaType"
            ]
        }
    ],
    "option": {
        "ClaimMail": {
            "type": "switch",
            "label": "$task.DailyRoutine.option.ClaimMail.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Daily_MailClick": {
                            "enabled": true
                        }
                    },
                    "label": "是"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Daily_MailClick": {
                            "enabled": false
                        }
                    },
                    "label": "否"
                }
            ]
        },
        "ClaimBattlePass": {
            "type": "switch",
            "label": "$task.DailyRoutine.option.ClaimBattlePass.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Daily_BattlePass": {
                            "enabled": true
                        }
                    },
                    "label": "是"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Daily_BattlePass": {
                            "enabled": false
                        }
                    },
                    "label": "否"
                }
            ]
        },
        "DailyNightmareMode": {
            "type": "select",
            "label": "梦魇巢穴",
            "default_case": "capture",
            "cases": [
                {
                    "name": "none",
                    "label": "不刷",
                    "pipeline_override": {
                        "Daily_CheckNightmareExplicit": {
                            "enabled": false
                        },
                        "Daily_CheckNightmareCapture": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "capture",
                    "label": "刷 1 个日常声骸",
                    "pipeline_override": {
                        "Daily_RunNightmare": {
                            "next": ["NightmareNest_MainCapture"]
                        },
                        "Daily_CheckNightmareExplicit": {
                            "enabled": false
                        },
                        "Daily_CheckNightmareCapture": {
                            "enabled": true
                        },
                        "NightmareNest_ScrollFound": {
                            "next": ["NightmareNest_ClickNestCapture"]
                        },
                        "NightmareNest_ScrollExhausted": {
                            "next": ["NightmareNest_SelectCanxiangCapture"]
                        },
                        "NightmareNest_ApproachDone": {
                            "next": ["NightmareNest_EnterFightCapture"]
                        },
                        "NightmareNest_ApproachFailed": {
                            "next": ["NightmareNest_OpenBookCapture"]
                        },
                        "NightmareNest_Done": {
                            "next": ["Daily_SpendStamina"]
                        }
                    }
                },
                {
                    "name": "nightmare",
                    "label": "仅刷梦魇拔除",
                    "pipeline_override": {
                        "Daily_RunNightmare": {
                            "next": ["NightmareNest_MainNightmare"]
                        },
                        "Daily_CheckNightmareExplicit": {
                            "enabled": true
                        },
                        "Daily_CheckNightmareCapture": {
                            "enabled": false
                        },
                        "NightmareNest_ScrollExhausted": {
                            "next": ["NightmareNest_Done"]
                        },
                        "NightmareNest_Done": {
                            "next": ["Daily_SpendStamina"]
                        }
                    }
                },
                {
                    "name": "canxiang",
                    "label": "仅刷残像聚落",
                    "pipeline_override": {
                        "Daily_RunNightmare": {
                            "next": ["NightmareNest_MainCanxiang"]
                        },
                        "Daily_CheckNightmareExplicit": {
                            "enabled": true
                        },
                        "Daily_CheckNightmareCapture": {
                            "enabled": false
                        },
                        "NightmareNest_Done": {
                            "next": ["Daily_SpendStamina"]
                        }
                    }
                },
                {
                    "name": "all",
                    "label": "全部梦魇巢穴",
                    "pipeline_override": {
                        "Daily_RunNightmare": {
                            "next": ["NightmareNest_Main"]
                        },
                        "Daily_CheckNightmareExplicit": {
                            "enabled": true
                        },
                        "Daily_CheckNightmareCapture": {
                            "enabled": false
                        },
                        "NightmareNest_Done": {
                            "next": ["Daily_SpendStamina"]
                        }
                    }
                }
            ]
        },
        "StaminaType": {
            "type": "select",
            "label": "$task.DailyRoutine.option.StaminaType.label",
            "default_case": "tacet",
            "cases": [
                {
                    "name": "tacet",
                    "option": [
                        "TacetSuppressionIndex"
                    ],
                    "pipeline_override": {
                        "Daily_CheckNightmareExplicit": {
                            "custom_recognition_param": {
                                "stamina_type": "tacet"
                            }
                        },
                        "Daily_CheckNightmareCapture": {
                            "custom_recognition_param": {
                                "stamina_type": "tacet"
                            },
                            "enabled": false
                        },
                        "Daily_SpendStamina": {
                            "enabled": true
                        },
                        "Daily_Stamina_Check": {
                            "custom_recognition_param": {
                                "min_stamina": 60
                            }
                        },
                        "Daily_Stamina_Has": {
                            "next": ["Tacet_Main"]
                        },
                        "Tacet_Done": {
                            "next": ["Daily_ClaimRewards"]
                        }
                    },
                    "label": "$task.DailyRoutine.option.StaminaType.cases.tacet.label"
                },
                {
                    "name": "forgery",
                    "option": [
                        "ForgeryChallengeIndex"
                    ],
                    "pipeline_override": {
                        "Daily_CheckNightmareExplicit": {
                            "custom_recognition_param": {
                                "stamina_type": "forgery"
                            }
                        },
                        "Daily_CheckNightmareCapture": {
                            "custom_recognition_param": {
                                "stamina_type": "forgery"
                            }
                        },
                        "Daily_SpendStamina": {
                            "enabled": true
                        },
                        "Daily_Stamina_Check": {
                            "custom_recognition_param": {
                                "min_stamina": 40
                            }
                        },
                        "Daily_Stamina_Has": {
                            "next": ["Forgery_Main"]
                        },
                        "Forgery_Done": {
                            "next": ["Daily_ClaimRewards"]
                        }
                    },
                    "label": "$task.DailyRoutine.option.StaminaType.cases.forgery.label"
                },
                {
                    "name": "simulation",
                    "option": [
                        "SimulationMaterial"
                    ],
                    "pipeline_override": {
                        "Daily_CheckNightmareExplicit": {
                            "custom_recognition_param": {
                                "stamina_type": "simulation"
                            }
                        },
                        "Daily_CheckNightmareCapture": {
                            "custom_recognition_param": {
                                "stamina_type": "simulation"
                            }
                        },
                        "Daily_SpendStamina": {
                            "enabled": true
                        },
                        "Daily_Stamina_Check": {
                            "custom_recognition_param": {
                                "min_stamina": 40
                            }
                        },
                        "Daily_Stamina_Has": {
                            "next": ["Simulation_Main"]
                        },
                        "Simulation_Done": {
                            "next": ["Daily_ClaimRewards"]
                        }
                    },
                    "label": "$task.DailyRoutine.option.StaminaType.cases.simulation.label"
                },
                {
                    "name": "none",
                    "pipeline_override": {
                        "Daily_CheckNightmareExplicit": {
                            "custom_recognition_param": {
                                "stamina_type": "none"
                            }
                        },
                        "Daily_CheckNightmareCapture": {
                            "custom_recognition_param": {
                                "stamina_type": "none"
                            },
                            "enabled": false
                        },
                        "Daily_SpendStamina": {
                            "enabled": false
                        },
                        "Daily_Stamina_Check": {
                            "custom_recognition_param": {
                                "min_stamina": 60
                            }
                        }
                    },
                    "label": "$task.DailyRoutine.option.StaminaType.cases.none.label"
                }
            ]
        },
        "TacetSuppressionIndex": {
            "type": "input",
            "label": "$task.DailyRoutine.option.TacetSuppressionIndex.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "1",
                    "pipeline_type": "int",
                    "verify": "^(?:[1-9]|1[0-7])$"
                }
            ],
            "pipeline_override": {
                "Tacet_SelectTarget": {
                    "custom_action_param": {
                        "serial_number": "{value}",
                        "total_number": 17
                    }
                }
            }
        },
        "ForgeryChallengeIndex": {
            "type": "input",
            "label": "$task.DailyRoutine.option.ForgeryChallengeIndex.label",
            "inputs": [
                {
                    "name": "value",
                    "default": "1",
                    "pipeline_type": "int",
                    "verify": "^(?:[1-9]|1[0-5])$"
                }
            ],
            "pipeline_override": {
                "Forgery_SelectTarget": {
                    "custom_action_param": {
                        "serial_number": "{value}",
                        "total_number": 15
                    }
                }
            }
        },
        "SimulationMaterial": {
            "type": "select",
            "label": "$task.DailyRoutine.option.SimulationMaterial.label",
            "default_case": "shell_credit",
            "cases": [
                {
                    "name": "resonator_exp",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "custom_action_param": {
                                "material": "resonator_exp",
                                "selection_index": 0
                            }
                        }
                    },
                    "label": "共鸣者经验"
                },
                {
                    "name": "weapon_exp",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "custom_action_param": {
                                "material": "weapon_exp",
                                "selection_index": 1
                            }
                        }
                    },
                    "label": "武器经验"
                },
                {
                    "name": "shell_credit",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "custom_action_param": {
                                "material": "shell_credit",
                                "selection_index": 2
                            }
                        }
                    },
                    "label": "贝币"
                }
            ]
        }
    }
}
