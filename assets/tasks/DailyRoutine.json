{
    "task": [
        {
            "name": "DailyRoutine",
            "label": "$task.DailyRoutine.label",
            "entry": "Daily_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "ClaimMail",
                "ClaimBattlePass",
                "DailyNightmareMode",
                "StaminaType"
            ]
        }
    ],
    "option": {
        "ClaimMail": {
            "type": "switch",
            "label": "$task.DailyRoutine.option.ClaimMail.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Daily_MailClick": {
                            "enabled": true
                        }
                    },
                    "label": "是"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Daily_MailClick": {
                            "enabled": false
                        }
                    },
                    "label": "否"
                }
            ]
        },
        "ClaimBattlePass": {
            "type": "switch",
            "label": "$task.DailyRoutine.option.ClaimBattlePass.label",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Daily_BattlePass": {
                            "enabled": true
                        }
                    },
                    "label": "是"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Daily_BattlePass": {
                            "enabled": false
                        }
                    },
                    "label": "否"
                }
            ]
        },
        "DailyNightmareMode": {
            "type": "select",
            "label": "梦魇巢穴",
            "default_case": "none",
            "cases": [
                {
                    "name": "none",
                    "label": "不刷"
                },
                {
                    "name": "capture",
                    "label": "刷 1 个日常声骸",
                    "pipeline_override": {
                        "Daily_CheckNightmare": {
                            "custom_recognition_param": {
                                "nightmare_mode": "capture"
                            }
                        },
                        "Daily_RunNightmare": {
                            "custom_action_param": {
                                "nightmare_mode": "capture"
                            }
                        }
                    }
                },
                {
                    "name": "all",
                    "label": "全部梦魇巢穴",
                    "pipeline_override": {
                        "Daily_CheckNightmare": {
                            "custom_recognition_param": {
                                "nightmare_mode": "all"
                            }
                        },
                        "Daily_RunNightmare": {
                            "custom_action_param": {
                                "nightmare_mode": "all"
                            }
                        }
                    }
                }
            ]
        },
        "StaminaType": {
            "type": "select",
            "label": "$task.DailyRoutine.option.StaminaType.label",
            "default_case": "tacet",
            "cases": [
                {
                    "name": "tacet",
                    "option": [
                        "TacetSuppressionIndex"
                    ],
                    "pipeline_override": {
                        "Daily_SpendStamina": {
                            "custom_recognition_param": {
                                "stamina_type": "tacet"
                            }
                        },
                        "Daily_Stamina_Has": {
                            "custom_action_param": {
                                "stamina_type": "tacet"
                            }
                        }
                    },
                    "label": "$task.DailyRoutine.option.StaminaType.cases.tacet.label"
                },
                {
                    "name": "forgery",
                    "option": [
                        "ForgeryChallengeIndex"
                    ],
                    "pipeline_override": {
                        "Daily_SpendStamina": {
                            "custom_recognition_param": {
                                "stamina_type": "forgery"
                            }
                        },
                        "Daily_Stamina_Has": {
