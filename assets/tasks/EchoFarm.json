{
    "task": [
        {
            "name": "EchoFarm",
            "label": "刷4C(大世界/副本)",
            "entry": "EchoFarm_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "farm"
            ],
            "option": [
                "TeleportToBoss",
                "RepeatFarmCount",
                "CombatWaitTime",
                "EchoPickupMethod",
                "EchoUseLiberation",
                "EchoSwitchHealer"
            ]
        }
    ],
    "option": {
        "TeleportToBoss": {
            "type": "select",
            "label": "传送至Boss",
            "default_case": "no",
            "cases": [
                {
                    "name": "no",
                    "label": "否"
                },
                {
                    "name": "weekly",
                    "label": "战歌重奏",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_type": "weekly",
                                "total_number": 9
                            }
                        },
                        "EchoFarm_BookOpen": {
                            "next": ["EchoFarm_SelectWeeklyTab"]
                        }
                    },
                    "option": [
                        "EchoFarmBossIndex",
                        "EchoFarmBossLevel"
                    ]
                },
                {
                    "name": "boss",
                    "label": "讨伐强敌",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_type": "boss",
                                "total_number": 20
                            }
                        },
                        "EchoFarm_BookOpen": {
                            "next": ["EchoFarm_SelectBossTab"]
                        }
                    },
                    "option": [
                        "EchoFarmBossIndex",
                        "EchoFarmBossName",
                        "EchoFarmBossLevel",
                        "EchoFarmBossProfile"
                    ]
                }
            ]
        },
        "EchoFarmBossIndex": {
            "type": "input",
            "label": "Boss序号 (从上到下)",
            "input_filter": "[1-9][0-9]?",
            "inputs": [
                {
                    "name": "value",
                    "default": "1",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "EchoFarm_TeleportBoss": {
                    "custom_action_param": {
                        "serial_number": "{value}"
                    }
                }
            }
        },
        "EchoFarmBossName": {
            "type": "input",
            "label": "Boss OCR 名称",
            "inputs": [
                {
                    "name": "value",
                    "default": ""
                }
            ],
            "pipeline_override": {
                "EchoFarm_TeleportBoss": {
                    "custom_action_param": {
                        "boss_name": "{value}"
                    }
                }
            }
        },
        "EchoFarmBossLevel": {
            "type": "select",
            "label": "Boss等级",
            "default_case": "80",
            "cases": [
                {
                    "name": "50",
                    "label": "50 级",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_level": "50"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_level": "50"
                            }
                        }
                    }
                },
                {
                    "name": "60",
                    "label": "60 级",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_level": "60"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_level": "60"
                            }
                        }
                    }
                },
                {
                    "name": "70",
                    "label": "70 级",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_level": "70"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_level": "70"
                            }
                        }
                    }
                },
                {
                    "name": "80",
                    "label": "80 级",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_level": "80"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_level": "80"
                            }
                        }
                    }
                },
                {
                    "name": "90",
                    "label": "90 级",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_level": "90"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_level": "90"
                            }
                        }
                    }
                }
            ]
        },
        "EchoFarmBossProfile": {
            "type": "select",
            "label": "Boss配置",
            "default_case": "other",
            "cases": [
                {
                    "name": "other",
                    "label": "其它"
                },
                {
                    "name": "hyvatia",
                    "label": "海维夏",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "hyvatia"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "hyvatia"
                            }
                        }
                    }
                },
                {
                    "name": "fallacy",
                    "label": "无归的谬误",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "fallacy"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "fallacy"
                            }
                        }
                    }
                },
                {
                    "name": "sentryconstruct",
                    "label": "异构武装",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "sentry_construct"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "sentry_construct"
                            }
                        }
                    }
                },
                {
                    "name": "lorelei",
                    "label": "罗蕾莱",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "lorelei"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "lorelei"
                            }
                        }
                    }
                },
                {
                    "name": "lionessofglory",
                    "label": "荣耀狮像",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "lioness_of_glory"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "lioness_of_glory"
                            }
                        }
                    }
                },
                {
                    "name": "fenrico",
                    "label": "芬莱克",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "fenrico"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "fenrico"
                            }
                        }
                    }
                },
                {
                    "name": "namelessexplorer",
                    "label": "无铭探索者",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "nameless_explorer"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "nameless_explorer"
                            }
                        }
                    }
                },
                {
                    "name": "nightmarehecate",
                    "label": "梦魇·赫卡忒",
                    "pipeline_override": {
                        "EchoFarm_TeleportBoss": {
                            "custom_action_param": {
                                "boss_profile": "nightmare_hecate"
                            }
                        },
                        "EchoFarm_EnterRealmFromF": {
                            "custom_action_param": {
                                "boss_profile": "nightmare_hecate"
                            }
                        }
                    }
                }
            ]
        },
        "RepeatFarmCount": {
            "type": "input",
            "label": "刷多少次",
            "input_filter": "[0-9]+",
            "inputs": [
                {
                    "name": "value",
                    "default": "10000",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "EchoFarm_NextRound": {
                    "custom_action_param": {
                        "max_rounds": "{value}"
                    }
                }
            }
        },
        "CombatWaitTime": {
            "type": "input",
            "label": "战斗开始前等待时间(秒)",
            "input_filter": "[0-9]+",
            "inputs": [
                {
                    "name": "value",
                    "default": "0",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "EchoFarm_TeleportBoss": {
                    "custom_action_param": {
                        "combat_wait_ms": "{value}"
                    }
                },
                "EchoFarm_EnterRealmFromF": {
                    "custom_action_param": {
                        "combat_wait_ms": "{value}"
                    }
                }
            }
        },
        "EchoPickupMethod": {
            "type": "select",
            "label": "搜索声骸方法",
            "default_case": "walk",
            "cases": [
                {
                    "name": "walk",
                    "label": "后退再前进",
                    "pipeline_override": {
                        "EchoFarm_Collect": {
                            "custom_action_param": {
                                "method": "walk",
                                "max_attempts": 4
                            }
                        }
                    }
                },
                {
                    "name": "run_in_circle",
                    "label": "转圈奔跑",
                    "pipeline_override": {
                        "EchoFarm_Collect": {
                            "custom_action_param": {
                                "method": "run_in_circle",
                                "max_attempts": 4
                            }
                        }
                    }
                },
                {
                    "name": "yolo",
                    "label": "Yolo模型",
                    "pipeline_override": {
                        "EchoFarm_Collect": {
                            "custom_action_param": {
                                "method": "yolo",
                                "max_attempts": 5
                            }
                        }
                    }
                }
            ]
        },
        "EchoUseLiberation": {
            "type": "switch",
            "label": "使用共鸣解放",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": false
                            }
                        }
                    }
                }
            ]
        },
        "EchoSwitchHealer": {
            "type": "switch",
            "label": "战斗结束后切换到治疗角色",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
