{
    "task": [
        {
            "name": "EchoFarm",
            "label": "刷4C(大世界/副本)",
            "entry": "EchoFarm_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "farm"
            ],
            "option": [
                "TeleportToBoss",
                "RepeatFarmCount",
                "CombatWaitTime",
                "EchoPickupMethod",
                "EchoUseLiberation",
                "EchoSwitchHealer"
            ]
        }
    ],
    "option": {
        "TeleportToBoss": {
            "type": "select",
            "label": "传送至Boss",
            "default_case": "no",
            "cases": [
                {
                    "name": "no",
                    "label": "否",
                    "pipeline_override": {
                        "EchoFarm_RoundGate": {
                            "next": [
                                "EchoFarm_LocalCheckCombat"
                            ]
                        }
                    }
                },
                {
                    "name": "weekly",
                    "label": "战歌重奏",
                    "pipeline_override": {
                        "EchoFarm_PostReviveProfile": {
                            "next": ["EchoFarm_ReviveOpenMap"]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_type": "weekly",
                                "total_number": 9
                            }
                        },
                        "EchoFarm_BookOpen": {
                            "next": ["EchoFarm_SelectWeeklyTab"]
                        }
                    },
                    "option": [
                        "EchoFarmBossIndex",
                        "EchoFarmBossLevel"
                    ]
                },
                {
                    "name": "boss",
                    "label": "讨伐强敌",
                    "pipeline_override": {
                        "EchoFarm_PostReviveProfile": {
                            "next": ["EchoFarm_ReviveOpenMap"]
                        },
                        "EchoFarm_ReviveBackstep": {
                            "next": ["EchoFarm_ReviveOpenBossBook"]
                        },
                        "EchoFarm_BookOpen": {
                            "next": ["EchoFarm_SelectBossTab"]
                        }
                    },
                    "option": [
                        "EchoFarmBossIndex",
                        "EchoFarmBossName",
                        "EchoFarmBossLevel",
                        "EchoFarmBossProfile"
                    ]
                }
            ]
        },
        "EchoFarmBossIndex": {
            "type": "input",
            "label": "Boss序号 (从上到下)",
            "inputs": [
                {
                    "name": "value",
                    "default": "1",
                    "pipeline_type": "int",
                    "verify": "[1-9][0-9]?"
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "serial_number": "{value}"
                    }
                }
            }
        },
        "EchoFarmBossName": {
            "type": "input",
            "label": "Boss OCR 名称",
            "inputs": [
                {
                    "name": "value",
                    "default": ""
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "boss_name": "{value}"
                    }
                }
            }
        },
        "EchoFarmBossLevel": {
            "type": "input",
            "label": "Boss等级",
            "inputs": [
                {
                    "name": "value",
                    "default": "80",
                    "pipeline_type": "string",
                    "verify": "^(50|60|70|80|90)$"
                }
            ],
            "pipeline_override": {
                "EchoFarm_SelectBossTarget": {
                    "custom_action_param": {
                        "boss_level": "{value}"
                    }
                },
                "EchoFarm_SelectRealmLevel": {
                    "expected": "{value}"
                }
            }
        },
        "EchoFarmBossProfile": {
            "type": "select",
            "label": "Boss配置",
            "default_case": "other",
            "cases": [
                {
                    "name": "other",
                    "label": "其它"
                },
                {
                    "name": "hyvatia",
                    "label": "海维夏",
                    "pipeline_override": {
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_HyvatiaResume"
                            ]
                        },
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 7
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "hyvatia"
                            }
                        }
                    }
                },
                {
                    "name": "ladyofthesea",
                    "label": "海之女",
                    "pipeline_override": {
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_HyvatiaResume"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lady_of_the_sea"
                            }
                        }
                    }
                },
                {
                    "name": "fallacy",
                    "label": "无归的谬误",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterFallacyWalkRight"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatFallacyReset"
                            ]
                        },
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "fallacy"
                            }
                        }
                    }
                },
                {
                    "name": "sentryconstruct",
                    "label": "异构武装",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "sentry_construct"
                            }
                        }
                    }
                },
                {
                    "name": "lorelei",
                    "label": "罗蕾莱",
                    "pipeline_override": {
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lorelei"
                            }
                        },
                        "EchoFarm_TeleportBoss": {
                            "next": [
                                "EchoFarm_LoreleiOpenMenu"
                            ]
                        }
                    }
                },
                {
                    "name": "lionessofglory",
                    "label": "荣耀狮像",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterWaitCustom": {
                            "custom_action_param": {
                                "delay_seconds": 5
                            }
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "lioness_of_glory"
                            }
                        }
                    }
                },
                {
                    "name": "fenrico",
                    "label": "芬莱克",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterPromptRetryReset"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatFenricoReset"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "fenrico"
                            }
                        }
                    }
                },
                {
                    "name": "namelessexplorer",
                    "label": "无铭探索者",
                    "pipeline_override": {
                        "EchoFarm_AfterRealmEnterProfile": {
                            "next": [
                                "EchoFarm_AfterRealmEnterNamelessWalkForward"
                            ]
                        },
                        "EchoFarm_PostCombatProfile": {
                            "next": [
                                "EchoFarm_PostCombatNamelessAdvance"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "nameless_explorer"
                            }
                        }
                    }
                },
                {
                    "name": "nightmarehecate",
                    "label": "梦魇·赫卡忒",
                    "pipeline_override": {
                        "EchoFarm_WaitRealmState": {
                            "next": [
                                "EchoFarm_Combat",
                                "EchoFarm_LocalStartNavigate"
                            ]
                        },
                        "EchoFarm_SelectBossTarget": {
                            "custom_action_param": {
                                "boss_profile": "nightmare_hecate"
                            }
                        }
                    }
                }
            ]
        },
        "RepeatFarmCount": {
            "type": "input",
            "label": "刷多少次",
            "inputs": [
                {
                    "name": "value",
                    "default": "10000",
                    "pipeline_type": "int",
                    "verify": "[0-9]+"
                }
            ],
            "pipeline_override": {
                "EchoFarm_RoundGate": {
                    "custom_recognition_param": {
                        "counter_key": "echo_farm_round",
                        "max_count": "{value}"
                    }
                }
            }
        },
        "CombatWaitTime": {
            "type": "input",
            "label": "战斗开始前等待时间(秒)",
            "inputs": [
                {
                    "name": "value",
                    "default": "0",
                    "pipeline_type": "int",
                    "verify": "[0-9]+"
                }
            ],
            "pipeline_override": {
                "EchoFarm_AfterRealmEnterWaitCustom": {
                    "custom_action_param": {
                        "delay_seconds": "{value}"
                    }
                }
            }
        },
        "EchoPickupMethod": {
            "type": "select",
            "label": "搜索声骸方法",
            "default_case": "walk",
            "cases": [
                {
                    "name": "walk",
                    "label": "后退再前进",
                    "pipeline_override": {
                        "EchoFarm_CollectMove": {
                            "next": [
                                "EchoFarm_CollectMoveWalkBack"
                            ]
                        }
                    }
                },
                {
                    "name": "run_in_circle",
                    "label": "转圈奔跑",
                    "pipeline_override": {
                        "EchoFarm_CollectMove": {
                            "next": [
                                "EchoFarm_CollectMoveCircleForward"
                            ]
                        }
                    }
                }
            ]
        },
        "EchoUseLiberation": {
            "type": "switch",
            "label": "使用共鸣解放",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "use_liberation": false
                            }
                        }
                    }
                }
            ]
        },
        "EchoSwitchHealer": {
            "type": "switch",
            "label": "战斗结束后切换到治疗角色",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "label": "是",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "否",
                    "pipeline_override": {
                        "EchoFarm_Fight": {
                            "custom_action_param": {
                                "switch_healer": false
                            }
                        }
                    }
                }
            ]
        }
    }
}
