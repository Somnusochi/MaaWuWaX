{
    "task": [
        {
            "name": "Simulation",
            "label": "$task.Simulation.label",
            "entry": "Simulation_Main",
            "controller": [
                "macOS",
                "macOS-Global"
            ],
            "group": [
                "domain"
            ],
            "option": [
                "MaterialSelection"
            ]
        }
    ],
    "option": {
        "MaterialSelection": {
            "type": "select",
            "label": "$option.MaterialSelection.label",
            "default_case": "shell_credit",
            "cases": [
                {
                    "name": "resonator_exp",
                    "label": "$option.MaterialSelection.cases.resonator_exp.label",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "target": [282, 122, 1, 1]
                        }
                    }
                },
                {
                    "name": "weapon_exp",
                    "label": "$option.MaterialSelection.cases.weapon_exp.label",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "target": [282, 180, 1, 1]
                        }
                    }
                },
                {
                    "name": "shell_credit",
                    "label": "$option.MaterialSelection.cases.shell_credit.label",
                    "pipeline_override": {
                        "Simulation_SelectMaterial": {
                            "target": [282, 238, 1, 1]
                        }
                    }
                }
            ]
        }
    }
}
