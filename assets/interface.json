{
    "interface_version": 2,
    "name": "MaaWuWaX",
    "label": "MaaWuWaX - 鸣潮助手",
    "title": "MaaWuWaX",
    "icon": "resource/image/app_icon_statusbar_tight.png",
    "description": "基于 MaaFramework 的鸣潮自动化助手 (macOS)",
    "github": "https://github.com/MaaWuWaX/MaaWuWaX",
    "license": "AGPL-3.0",
    "version": "0.2.0",
    "languages": {
        "zh_cn": "locales/zh_cn.json",
        "en_us": "locales/en_us.json"
    },
    "agent": [
        {
            "child_exec": "agent/go-service",
            "child_args": []
        }
    ],
    "controller": [
        {
            "name": "macOS",
            "label": "macOS (ScreenCaptureKit)",
            "type": "MacOS",
            "macos": {
                "screencap": "ScreenCaptureKit",
                "input": "PostToPid"
            }
        },
        {
            "name": "macOS-Global",
            "label": "macOS (Global Input)",
            "type": "MacOS",
            "macos": {
                "screencap": "ScreenCaptureKit",
                "input": "GlobalEvent"
            }
        }
    ],
    "resource": [
        {
            "name": "Official",
            "label": "官方资源",
            "path": [
                "resource"
            ]
        }
    ],
    "group": [
        {
            "name": "realtime",
            "label": "$group.realtime.label",
            "default_expand": true
        },
        {
            "name": "combat",
            "label": "$group.combat.label",
            "default_expand": true
        },
        {
            "name": "open_world",
            "label": "$group.open_world.label",
            "default_expand": true
        },
        {
            "name": "daily",
            "label": "$group.daily.label",
            "default_expand": true
        },
        {
            "name": "farm",
            "label": "$group.farm.label",
            "default_expand": true
        },
        {
            "name": "domain",
            "label": "$group.domain.label",
            "default_expand": true
        },
        {
            "name": "echo",
            "label": "$group.echo.label",
            "default_expand": true
        },
        {
            "name": "diagnosis",
            "label": "$group.diagnosis.label",
            "default_expand": false
        }
    ],
    "task": [],
    "import": [
        "tasks/RealTime.json",
        "tasks/AutoCombat.json",
        "tasks/AutoPick.json",
        "tasks/SkipDialog.json",
        "tasks/FastTravel.json",
        "tasks/FarmMap.json",
        "tasks/AutoLogin.json",
        "tasks/MouseReset.json",
        "tasks/DailyRoutine.json",
        "tasks/MultiAccountDaily.json",
        "tasks/NightmareNest.json",
        "tasks/Tacet.json",
        "tasks/Forgery.json",
        "tasks/Simulation.json",
        "tasks/EchoFarm.json",
        "tasks/FarmBoss.json",
        "tasks/AutoRogue.json",
        "tasks/EnhanceEcho.json",
        "tasks/ChangeEcho.json",
        "tasks/FiveToOne.json",
        "tasks/Diagnosis.json",
        "tasks/preset/RealtimeAssist.json",
        "tasks/preset/DailyFull.json",
        "tasks/preset/EchoFarming.json",
        "tasks/preset/MultiAccountDaily.json",
        "tasks/preset/DungeonFarming.json",
        "tasks/preset/NightmareNest.json",
        "tasks/preset/AutoRogue.json",
        "tasks/preset/EchoEnhance.json"
    ]
}
