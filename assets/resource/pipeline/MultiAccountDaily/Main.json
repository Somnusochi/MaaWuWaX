{
    "MultiAccountDaily_Init": {
        "action": "Custom",
        "custom_action": "MultiAccountResetState",
        "next": ["Daily_Main"]
    },
    "MultiAccountDaily_SwitchGate": {
        "action": "DoNothing",
        "next": ["MultiAccountDaily_Switch"]
    },
    "MultiAccountDaily_Switch": {
        "recognition": "Custom",
        "custom_recognition": "MultiAccountCanSwitch",
        "custom_recognition_param": {
            "max_accounts": 2
        },
        "next": ["MultiAccountDaily_OpenEsc"],
        "on_error": ["MultiAccountDaily_Done"]
    },
    "MultiAccountDaily_OpenEsc": {
        "action": "ClickKey",
        "key": 53,
        "post_delay": 1500,
        "next": ["MultiAccountDaily_CheckEscSetting"]
    },
    "MultiAccountDaily_CheckEscSetting": {
        "recognition": "TemplateMatch",
        "template": "esc_setting.png",
        "threshold": 0.6,
        "next": ["MultiAccountDaily_ClickLogout"],
        "timeout": 1000,
        "on_error": ["MultiAccountDaily_OpenEscRetry"]
    },
    "MultiAccountDaily_OpenEscRetry": {
        "action": "ClickKey",
        "key": 53,
        "post_delay": 1000,
        "next": ["MultiAccountDaily_CheckEscSettingRetry"]
    },
    "MultiAccountDaily_CheckEscSettingRetry": {
        "recognition": "TemplateMatch",
        "template": "esc_setting.png",
        "threshold": 0.6,
        "next": ["MultiAccountDaily_ClickLogout"],
        "timeout": 1500,
        "on_error": ["MultiAccountDaily_OpenEscRetryLast"]
    },
    "MultiAccountDaily_OpenEscRetryLast": {
        "action": "ClickKey",
        "key": 53,
        "post_delay": 1500,
        "next": ["MultiAccountDaily_CheckEscSettingLast"]
    },
    "MultiAccountDaily_CheckEscSettingLast": {
        "recognition": "TemplateMatch",
        "template": "esc_setting.png",
        "threshold": 0.6,
        "next": ["MultiAccountDaily_ClickLogout"],
        "timeout": 1500,
        "on_error": ["MultiAccountDaily_StopOnLogoutMenuFailure"]
    },
    "MultiAccountDaily_ClickLogout": {
        "action": "Click",
        "target": [51, 691, 1, 1],
        "post_delay": 1000,
        "next": ["MultiAccountDaily_ConfirmLogout"]
    },
    "MultiAccountDaily_StopOnLogoutMenuFailure": {
        "action": "Custom",
        "custom_action": "StopTask",
        "next": []
    },
    "MultiAccountDaily_ConfirmLogout": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "TemplateMatch",
                "template": "btn_yellow_confirm.png",
                "threshold": 0.7
            },
            {
                "recognition": "TemplateMatch",
                "template": "confirm_btn_hcenter_vcenter.png",
                "threshold": 0.7
            },
            {
                "recognition": "OCR",
                "expected": "确认"
            },
            {
                "recognition": "OCR",
                "expected": "Confirm"
            }
        ],
        "action": "Click",
        "post_delay": 3000,
        "next": ["MultiAccountDaily_WaitLoginReady"],
        "on_error": ["MultiAccountDaily_WaitLoginReadyFallback"]
    },
    "MultiAccountDaily_WaitLoginReady": {
        "recognition": "Custom",
        "custom_recognition": "MultiAccountCurrentVisible",
        "next": ["MultiAccountDaily_MarkCurrent"],
        "timeout": 30000,
        "on_error": ["MultiAccountDaily_MarkCurrentBestEffort"]
    },
    "MultiAccountDaily_WaitLoginReadyFallback": {
        "recognition": "Custom",
        "custom_recognition": "MultiAccountCurrentVisible",
        "next": ["MultiAccountDaily_MarkCurrent"],
        "timeout": 30000,
        "on_error": ["MultiAccountDaily_MarkCurrentBestEffort"]
    },
    "MultiAccountDaily_MarkCurrent": {
        "action": "Custom",
        "custom_action": "MultiAccountMarkCurrent",
        "next": ["MultiAccountDaily_ResetSelectionRetry"]
    },
    "MultiAccountDaily_MarkCurrentBestEffort": {
        "action": "Custom",
        "custom_action": "MultiAccountMarkCurrent",
        "next": ["MultiAccountDaily_ResetSelectionRetry"]
    },
    "MultiAccountDaily_Login": {
        "next": ["MultiAccountDaily_WaitWorld", "Login_HandleScreen"],
        "post_delay": 2000,
        "timeout": 180000,
        "on_error": ["MultiAccountDaily_SkipFailed"]
    },
    "MultiAccountDaily_WaitWorld": {
        "recognition": "TemplateMatch",
        "template": "minimap.png",
        "threshold": 0.7,
        "roi": [1050, 20, 200, 160],
        "next": ["Daily_Main"],
        "post_delay": 2000,
        "timeout": 180000,
        "on_error": ["MultiAccountDaily_SkipFailed"]
    },
    "MultiAccountDaily_SkipFailed": {
        "action": "Custom",
        "custom_action": "MultiAccountMarkFailed",
        "next": ["MultiAccountDaily_SwitchGate"],
        "post_delay": 1000
    },
    "MultiAccountDaily_Done": {
        "next": []
    }
}
