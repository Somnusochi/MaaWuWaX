{
    "FarmMap_Main": {
        "next": [
            "FarmMap_LoadPath"
        ]
    },
    "FarmMap_LoadPath": {
        "action": "Custom",
        "custom_action": "FarmMapLoadPath",
        "custom_action_param": {
            "max_step_distance": 144,
            "min_stars": 3
        },
        "next": [
            "FarmMap_WaitWorld"
        ],
        "post_delay": 1000
    },
    "FarmMap_WaitWorld": {
        "recognition": "TemplateMatch",
        "template": "minimap.png",
        "threshold": 0.7,
        "roi": [
            1050,
            20,
            200,
            160
        ],
        "next": [
            "FarmMap_Loop"
        ],
        "timeout": 30000
    },
    "FarmMap_Loop": {
        "next": [
            "FarmMap_Done",
            "FarmMap_Revive",
            "FarmMap_Pickup",
            "FarmMap_Combat",
            "FarmMap_Walk"
        ]
    },
    "FarmMap_Done": {
        "recognition": "Custom",
        "custom_recognition": "FarmMapPathDone",
        "next": [
            "FarmMap_Stop"
        ]
    },
    "FarmMap_Stop": {
        "action": "DoNothing",
        "next": []
    },
    "FarmMap_Revive": {
        "recognition": "TemplateMatch",
        "template": "revive_confirm_hcenter_vcenter.png",
        "threshold": 0.6,
        "action": "Click",
        "next": [
            "FarmMap_ResetTracker"
        ],
        "post_delay": 3000
