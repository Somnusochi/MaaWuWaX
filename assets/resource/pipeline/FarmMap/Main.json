{
    "FarmMap_Main": {
        "next": [
            "FarmMap_LoadPath"
        ]
    },
    "FarmMap_LoadPath": {
        "action": "Custom",
        "custom_action": "FarmMapLoadPath",
        "custom_action_param": {
            "max_step_distance": 144,
            "min_stars": 3
        },
        "next": [
            "FarmMap_CloseBigMap"
        ],
        "post_delay": 1000
    },
    "FarmMap_CloseBigMap": {
        "action": "ClickKey",
        "key": 53,
        "next": [
            "FarmMap_WaitWorld"
        ],
        "post_delay": 1200
    },
    "FarmMap_WaitWorld": {
        "recognition": "TemplateMatch",
        "template": "minimap.png",
        "threshold": 0.7,
        "roi": [
            1050,
            20,
            200,
            160
        ],
        "next": [
            "FarmMap_Locate"
        ],
        "timeout": 30000
    },
    "FarmMap_Loop": {
        "next": [
            "FarmMap_Done",
            "FarmMap_Revive",
            "FarmMap_Pickup",
            "FarmMap_Combat",
            "FarmMap_Walk"
        ]
    },
    "FarmMap_Done": {
        "recognition": "Custom",
        "custom_recognition": "FarmMapPathDone",
        "next": [
            "FarmMap_Stop"
        ]
    },
    "FarmMap_Stop": {
        "action": "DoNothing",
        "next": []
    },
    "FarmMap_Revive": {
        "recognition": "TemplateMatch",
        "template": "revive_confirm_hcenter_vcenter.png",
        "threshold": 0.6,
        "action": "Click",
        "next": [
            "FarmMap_ResetTracker"
        ],
        "post_delay": 3000
    },
    "FarmMap_ResetTracker": {
        "action": "Custom",
        "custom_action": "FarmMapResetTracker",
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 1000
    },
    "FarmMap_Combat": {
        "recognition": "TemplateMatch",
        "template": "has_target.png",
        "threshold": 0.65,
        "next": [
            "FarmMap_Fight",
            "FarmMap_Walk"
        ]
    },
    "FarmMap_Fight": {
        "action": "Custom",
        "custom_action": "CombatMain",
        "custom_action_param": {
            "auto_target": true,
            "use_liberation": true
        },
        "next": [
            "FarmMap_Pickup",
            "FarmMap_Loop"
        ],
        "timeout": 120000
    },
    "FarmMap_Walk": {
        "action": "Custom",
        "custom_action": "FarmMapWalkStepCpp",
        "custom_action_param": {
            "reach_distance": 24,
            "search_radius": 280,
            "walk_ms": 850,
            "stuck_steps": [
                {
                    "key": "SPACE",
                    "step_ms": 80,
                    "delay_ms": 250
                },
                {
                    "key": "A",
                    "step_ms": 700,
                    "delay_ms": 250
                },
                {
                    "key": "D",
                    "step_ms": 700,
                    "delay_ms": 250
                },
                {
                    "key": "T",
                    "step_ms": 80,
                    "delay_ms": 250
                }
            ]
        },
        "next": [
            "FarmMap_Loop"
        ],
        "on_error": [
            "FarmMap_Locate"
        ],
        "post_delay": 200
    },
    "FarmMap_WalkGo": {
        "action": "Custom",
        "custom_action": "FarmMapWalkStep",
        "custom_action_param": {
            "reach_distance": 24,
            "search_radius": 280,
            "walk_ms": 850,
            "stuck_steps": [
                {
                    "key": "SPACE",
                    "step_ms": 80,
                    "delay_ms": 250
                },
                {
                    "key": "A",
                    "step_ms": 700,
                    "delay_ms": 250
                },
                {
                    "key": "D",
                    "step_ms": 700,
                    "delay_ms": 250
                },
                {
                    "key": "T",
                    "step_ms": 80,
                    "delay_ms": 250
                }
            ]
        },
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 200
    },
    "FarmMap_Locate": {
        "recognition": "Custom",
        "custom_recognition": "MapLocateRecognition",
        "custom_recognition_param": {
            "force_global_search": true
        },
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 500
    }
}
