        ],
        "post_delay": 200
    },
    "FarmMap_WalkGo": {
        "action": "Custom",
        "custom_action": "FarmMapWalkStep",
        "custom_action_param": {
            "reach_distance": 24,
            "search_radius": 280,
            "walk_ms": 850
        },
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 200
    },
    "FarmMap_Locate": {
        "recognition": "Custom",
        "custom_recognition": "MapLocateRecognition",
        "custom_recognition_param": {
            "search_radius": 420
        },
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 500
    }
