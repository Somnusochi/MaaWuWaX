    "FarmMap_ResetTracker": {
        "action": "Custom",
        "custom_action": "FarmMapResetTracker",
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 1000
    },
    "FarmMap_Pickup": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f_hcenter_vcenter.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f.png",
                "threshold": 0.65
            },
            {
                "recognition": "TemplateMatch",
                "template": "echo_orb.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "treasure_icon.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "absorb_zh_CN.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "absorb_en_US.png",
                "threshold": 0.6
            }
        ],
        "next": [
            "FarmMap_Collect",
            "FarmMap_Combat",
            "FarmMap_Walk"
        ],
        "post_delay": 500
    },
    "FarmMap_Collect": {
        "action": "Custom",
        "custom_action": "PickEnhanced",
        "custom_action_param": {
            "max_attempts": 5
        },
        "next": [
            "FarmMap_Loop"
        ],
        "post_delay": 500
    },
    "FarmMap_Combat": {
        "recognition": "TemplateMatch",
        "template": "has_target.png",
        "threshold": 0.65,
        "next": [
            "FarmMap_Fight",
            "FarmMap_Walk"
        ]
    },
    "FarmMap_Fight": {
        "action": "Custom",
        "custom_action": "CombatMain",
        "custom_action_param": {
            "auto_target": true,
            "use_liberation": true
        },
        "next": [
            "FarmMap_Pickup",
            "FarmMap_Loop"
        ],
        "timeout": 120000
    },
    "FarmMap_Walk": {
        "action": "Custom",
        "custom_action": "FarmMapWalkStep",
        "custom_action_param": {
            "reach_distance": 24,
            "search_radius": 280,
            "walk_ms": 850
