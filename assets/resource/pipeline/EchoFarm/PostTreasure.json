{
    "EchoFarm_PostCombatTreasureLoop": {
        "next": ["EchoFarm_PostCombatTreasureCheckCombat"],
        "timeout": 12000,
        "on_error": ["EchoFarm_PostCombatResume"]
    },
    "EchoFarm_PostCombatTreasureCheckCombat": {
        "recognition": "TemplateMatch",
        "template": "has_target.png",
        "threshold": 0.7,
        "next": ["EchoFarm_Fight"],
        "on_error": ["EchoFarm_PostCombatTreasureCheckClaim"]
    },
    "EchoFarm_PostCombatTreasureCheckClaim": {
        "recognition": "TemplateMatch",
        "template": "claim_btn.png",
        "threshold": 0.7,
        "action": "Click",
        "next": ["EchoFarm_PostCombat"],
        "post_delay": 1500,
        "on_error": ["EchoFarm_PostCombatCheckRealmPrompt"]
    },
    "EchoFarm_PostCombatCheckRealmPrompt": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "OCR",
                "expected": "挑战"
            },
            {
                "recognition": "OCR",
                "expected": "Challenge"
            },
            {
                "recognition": "TemplateMatch",
                "template": "gray_button_challenge.png",
                "threshold": 0.6
            }
        ],
        "next": ["EchoFarm_EnterRealmFromF"],
        "on_error": ["EchoFarm_PostCombatCheckPickupPrompt"]
    },
    "EchoFarm_PostCombatCheckPickupPrompt": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f_hcenter_vcenter.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f.png",
                "threshold": 0.65
            },
            {
                "recognition": "TemplateMatch",
                "template": "absorb_zh_CN.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "absorb_en_US.png",
                "threshold": 0.6
            }
        ],
        "next": ["EchoFarm_Collect"],
        "on_error": ["EchoFarm_PostCombatTreasureCheckVisible"]
    },
    "EchoFarm_PostCombatTreasureCheckVisible": {
        "recognition": "TemplateMatch",
        "template": "treasure_icon.png",
        "threshold": 0.6,
        "next": ["EchoFarm_PostCombatTreasureStep"],
        "on_error": ["EchoFarm_PostCombatResume"]
    },
    "EchoFarm_PostCombatTreasureStep": {
        "action": "Click",
        "target": [640, 360, 1, 1],
        "next": ["EchoFarm_PostCombatTreasureForward"],
        "post_delay": 100
    },
    "EchoFarm_PostCombatTreasureForward": {
        "action": "KeyDown",
        "key": 13,
        "next": ["EchoFarm_PostCombatTreasureForwardRelease"],
        "post_delay": 700
    },
    "EchoFarm_PostCombatTreasureForwardRelease": {
        "action": "KeyUp",
        "key": 13,
        "next": ["EchoFarm_PostCombatTreasureLoop"],
        "post_delay": 120
    }
}
