    "EchoFarm_AfterRealmEnterFallacyApproach": {
        "action": "Custom",
        "custom_action": "ForwardApproachUntil",
        "custom_action_param": {
            "direction": "forward",
            "timeout_ms": 20000,
            "step_ms": 600,
            "sprint": true,
            "center_camera_interval_ms": 1200,
            "stop_on_combat": true,
            "stop_on_f_prompt": true,
            "stop_on_treasure": true,
            "combat_node": "EchoFarm_TeleportWalkCombat",
