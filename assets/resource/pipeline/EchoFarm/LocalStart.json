{
    "EchoFarm_LocalCheckCombat": {
        "recognition": "TemplateMatch",
        "template": "has_target.png",
        "threshold": 0.7,
        "next": [
            "EchoFarm_Fight"
        ],
        "on_error": [
            "EchoFarm_LocalCheckRealmFPrompt"
        ]
    },
    "EchoFarm_LocalCheckRealmFPrompt": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f_hcenter_vcenter.png",
                "threshold": 0.6
            },
            {
                "recognition": "TemplateMatch",
                "template": "pick_up_f.png",
                "threshold": 0.65
            },
            {
                "recognition": "OCR",
                "expected": "挑战"
            },
            {
                "recognition": "OCR",
                "expected": "Challenge"
            }
        ],
        "next": [
            "EchoFarm_EnterRealmFromF"
        ],
        "on_error": [
            "EchoFarm_LocalCheckWorld"
        ]
    },
    "EchoFarm_LocalCheckWorld": {
        "recognition": "TemplateMatch",
        "template": "minimap.png",
        "threshold": 0.7,
        "roi": [1050, 20, 200, 160],
        "next": [
            "EchoFarm_LocalStartApproach"
        ],
        "on_error": [
            "EchoFarm_NextRound"
        ]
    },
    "EchoFarm_LocalStartApproach": {
        "action": "Custom",
        "custom_action": "ForwardApproachUntil",
        "custom_action_param": {
            "direction": "forward",
            "timeout_ms": 8000,
            "step_ms": 600,
            "sprint": true,
            "center_camera_interval_ms": 1200,
            "stop_on_combat": true,
            "stop_on_f_prompt": true,
            "stop_on_treasure": true,
            "combat_node": "EchoFarm_TeleportWalkCombat",
            "f_prompt_node": "EchoFarm_TeleportWalkFPrompt",
            "treasure_node": "EchoFarm_TeleportWalkTreasure"
        },
        "next": [
            "EchoFarm_LocalStartCombatResult"
        ],
        "post_delay": 100
    },
    "EchoFarm_LocalStartCombatResult": {
        "recognition": "Custom",
        "custom_recognition": "ForwardApproachResult",
        "custom_recognition_param": {
            "expected": "combat"
        },
        "next": [
            "EchoFarm_Fight"
        ],
        "on_error": [
            "EchoFarm_LocalStartFResult"
        ]
    },
    "EchoFarm_LocalStartFResult": {
        "recognition": "Custom",
        "custom_recognition": "ForwardApproachResult",
        "custom_recognition_param": {
            "expected": "f_prompt"
        },
        "next": [
            "EchoFarm_EnterRealmFromF"
        ],
        "on_error": [
            "EchoFarm_LocalStartTreasureResult"
        ]
    },
    "EchoFarm_LocalStartTreasureResult": {
        "recognition": "Custom",
        "custom_recognition": "ForwardApproachResult",
        "custom_recognition_param": {
            "expected": "treasure"
        },
        "next": [
            "EchoFarm_PostCombatTreasureLoop"
        ],
        "on_error": [
            "EchoFarm_LocalStartNavigate"
        ]
    },
    "EchoFarm_LocalStartNavigate": {
        "next": [
            "EchoFarm_Navigate"
        ]
    }
}
