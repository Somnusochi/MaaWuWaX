            "EchoFarm_TeleportNext"
        ]
    },
    "EchoFarm_TeleportNext": {
        "action": "Custom",
        "custom_action": "TeleportBoss",
        "custom_action_param": {
            "boss_type": "boss"
        },
        "next": [
            "EchoFarm_DetectDead",
            "EchoFarm_ScanEcho",
            "EchoFarm_Navigate"
        ],
        "post_delay": 3000
    }
