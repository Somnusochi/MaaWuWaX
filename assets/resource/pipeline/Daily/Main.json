{
    "Daily_Main": {
        "next": ["Daily_HandlePopups", "Daily_EnsureWorld"]
    },
    "Daily_HandlePopups": {
        "recognition": "Or",
        "any_of": [
            {
                "recognition": "TemplateMatch",
                "template": "monthly_card.png",
                "threshold": 0.7
            },
            {
                "recognition": "TemplateMatch",
                "template": "claim_btn.png",
                "threshold": 0.7
            },
            {
                "recognition": "TemplateMatch",
                "template": "claim_cancel_button_hcenter_vcenter.png",
                "threshold": 0.7
            },
            {
                "recognition": "TemplateMatch",
                "template": "revive_confirm_hcenter_vcenter.png",
                "threshold": 0.7
            },
            {
                "recognition": "OCR",
                "expected": "登录奖励"
            },
            {
                "recognition": "OCR",
                "expected": "Login Reward"
            },
            {
                "recognition": "OCR",
                "expected": "关闭"
            },
            {
                "recognition": "OCR",
                "expected": "Close"
            },
            {
                "recognition": "OCR",
                "expected": "确定"
            },
            {
                "recognition": "OCR",
                "expected": "Confirm"
            }
        ],
        "action": "Click",
        "next": ["Daily_Main"]
    },
    "Daily_EnsureWorld": {
        "recognition": "TemplateMatch",
        "template": "minimap.png",
        "threshold": 0.7,
        "next": ["Daily_OpenBook"],
        "post_delay": 1000
    },
    "Daily_OpenBook": {
        "action": "ClickKey",
        "key": 120,
        "next": ["Daily_SelectQuest"],
        "post_delay": 2000
    },
    "Daily_SelectQuest": {
        "recognition": "TemplateMatch",
        "template": "gray_book_quest.png",
        "threshold": 0.6,
        "action": "Click",
        "next": ["Daily_CheckProgress"],
        "post_delay": 1200,
        "timeout": 5000
    },
    "Daily_CheckProgress": {
        "recognition": "Custom",
        "custom_recognition": "DailyProgress",
        "next": ["Daily_CheckNightmare", "Daily_SpendStamina", "Daily_ClaimRewards"],
        "timeout": 8000
    },
    "Daily_CheckNightmare": {
        "recognition": "Custom",
        "custom_recognition": "DailyNeedsNightmare",
        "custom_recognition_param": {
            "nightmare_mode": "none"
        },
        "next": ["Daily_RunNightmare"],
        "on_error": ["Daily_SpendStamina"]
    },
    "Daily_RunNightmare": {
        "action": "Custom",
        "custom_action": "RunNightmareNest",
        "custom_action_param": {
            "nightmare_mode": "capture"
        },
        "next": ["Daily_SpendStamina"]
    },
    "Daily_SpendStamina": {
        "recognition": "Custom",
        "custom_recognition": "DailyNeedsStamina",
        "custom_recognition_param": {
            "stamina_type": "tacet"
        },
        "next": ["Daily_Stamina_Check"],
        "on_error": ["Daily_ClaimRewards"]
    },
    "Daily_ClaimRewards": {
        "action": "Custom",
        "custom_action": "ClaimDailyRewards",
        "next": ["Daily_ClaimMail"],
        "post_delay": 1000
    },
    "Daily_ClaimMail": {
        "recognition": "Custom",
        "custom_recognition": "IsMailEnabled",
        "action": "ClickKey",
        "key": 53,
        "post_delay": 1500,
        "next": ["Daily_MailClick", "Daily_BattlePass"]
    },
    "Daily_MailClick": {
        "action": "Custom",
        "custom_action": "ClaimMail",
        "next": ["Daily_BattlePass"]
    },
    "Daily_BattlePass": {
        "action": "Custom",
        "custom_action": "ClaimBattlePass",
        "next": ["Daily_Done"]
    },
    "Daily_Done": {
        "next": []
    }
}
